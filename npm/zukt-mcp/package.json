{
  "name": "zukt-mcp",
  "version": "0.2.0",
  "private": false,
  "description": "Local MCP runner for ZUKT with Qdrant/Ollama checks and integrated prepare command",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "zukt-mcp": "bin/zukt-mcp.js"
  },
  "files": [
    "bin/",
    "docker/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
