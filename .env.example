MCP_SERVER_NAME=zukt
MCP_SERVER_VERSION=0.1.0
ZOEKT_BACKEND=http
ZOEKT_AUTOPILOT=true
ZOEKT_HTTP_BASE_URL=http://127.0.0.1:6070
ZOEKT_HTTP_TIMEOUT=5s
# Optional CSV. Repos can also be managed with a ".zukt" marker file in each repo root.
ZOEKT_REPOS=
ZOEKT_ALLOWED_ROOTS=/home/your-user
ZOEKT_INDEX_DIR=./zoekt-index
ZOEKT_FORCE_REINDEX=false
ZOEKT_EXCLUDE_DIRS=.git,node_modules,.venv,dist,build
